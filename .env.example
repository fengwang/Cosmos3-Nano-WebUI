# Cosmos3-Nano-WebUI — local-build Docker/Compose configuration (MIG-S6).
# Copy to `.env` at the REPO ROOT (the Makefile auto-passes it via --env-file). If you
# invoke `docker compose` directly, run from the repo root with `--env-file .env`, or
# place the file at `deploy/.env` (Compose's project dir). All values are
# operator-configurable (INV-4). Defaults are repo-relative placeholders — no private
# or absolute paths are baked in (INV-1). Checkpoint facts/semantics: docs/model_setup.md.

# ─── WebUI ↔ API wiring ──────────────────────────────────────────────────────
API_INTERNAL_URL=http://api:8000        # server-side BFF target (compose service name)
BIND_ADDR=127.0.0.1                     # host interface for published ports; set 0.0.0.0 for LAN
WEBUI_PORT=3000                         # host port for the WebUI
API_PORT=8000                           # host port for the API (health/smoke)

# ─── Generation engine wiring (these defaults match the code; shown for clarity) ─
COSMOS3_GEN_ENGINE=vllm_omni            # generation engine selector
COSMOS3_VLLM_OMNI_URL=http://vllm-omni:8000        # generation container base URL
COSMOS3_GEN_CONTAINER=cosmos3-nano-webui-vllm-omni # container the api starts/stops
COSMOS3_DEVICE=cuda                     # compute device (GPU is a MIG-S8 gate)

# ─── Deployed checkpoint (serve exactly one: fp8 XOR nvfp4) ───────────────────
COSMOS3_CHECKPOINT_LABEL=fp8            # fp8 | nvfp4 (compose stacks set this per stack)

# Host directories to bind-mount (download weights here first — see below).
# Compose runs with project dir = deploy/, so a relative value is resolved from
# deploy/; `../models/...` therefore means <repo>/models/... (where downloads land).
# For overrides prefer an ABSOLUTE path (e.g. /path/to/fp8-weights) to avoid ambiguity.
#
# WARNING (GPU-S3, R-11): if you override either variable below to point at a
# directory from an earlier download or a different session, `docker compose ...
# up -d` will silently bind-mount THAT content — it does not know or care whether
# it is fresh, stale, or pre-fix. This bit a real validation session: a local `.env`
# pinned these to a leftover pre-fix checkpoint directory, and every generation
# check against it silently used stale content instead of a fresh `hf download`.
# Before treating any `up -d` run as validating a *fresh* checkpoint: (1) confirm
# the resolved mount with `docker compose --env-file .env -f deploy/docker-compose.
# fp8.yml config` (or the nvfp4 file) and check the `source:` path is the fresh
# directory you actually just downloaded to, not a leftover from a previous run;
# (2) if it isn't, either unset the override so the repo-relative default applies,
# or point it explicitly at the fresh download directory.
COSMOS3_FP8_DIR=../models/Cosmos3-Nano-FP8-Blockwise      # for the fp8 stack
COSMOS3_NVFP4_DIR=../models/Cosmos3-Nano-NVFP4-Blockwise  # for the nvfp4 stack
COSMOS3_BASE_DIR=../models/Cosmos3-Nano                   # BF16 base (reasoning overlay)

# In-container mount targets set by the compose stacks (the code's own fallback
# defaults differ — /data/models/* per docs/model_setup.md — and are overridden here).
COSMOS3_MODEL_DIR=/models/checkpoint                     # quantized generation checkpoint
COSMOS3_REASONER_MODEL_DIR=/models/base                  # BF16 reasoner (reasoning overlay)
COSMOS3_BASE_ACTION_DIR=/models/base/transformer         # BF16 action tensors

# ─── Reasoning (optional overlay: docker-compose.reasoning.yml) ───────────────
COSMOS3_VLLM_BIN=vllm                   # reasoner subprocess binary (needs GPU + BF16 base)

# ─── vLLM-Omni pin (MIG-S2) ───────────────────────────────────────────────────
# Fork: git@github.com:fengwang/vllm-omni.git
# Tag:  cosmos3-nano-webui-mig-s2   Commit: 697035018b70cef76b974a909d23371a9984c3f2
# Install (baked into deploy/vllm-omni.Dockerfile):
#   pip install "git+https://github.com/fengwang/vllm-omni.git@cosmos3-nano-webui-mig-s2"

# ─── Downloading the pinned public checkpoints (ungated; no auth required) ─────
# hf download wfen/Cosmos3-Nano-FP8-Blockwise \
#   --revision 9bf5d6ae164688487bdb71947ccc6ebe70d12900 \
#   --local-dir ./models/Cosmos3-Nano-FP8-Blockwise
# hf download wfen/Cosmos3-Nano-NVFP4-Blockwise \
#   --revision 5514c42b9759739f545e0d0dee453db8d8525fbc \
#   --local-dir ./models/Cosmos3-Nano-NVFP4-Blockwise
# huggingface-cli download nvidia/Cosmos3-Nano \
#   --revision fea6e03ac3d7884b4105ed8ee79fc480fca70965 \
#   --local-dir ./models/Cosmos3-Nano
